    </div>{{-- end .no-print --}}

    {{-- ══════════════════════════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════════════════════════ --}}
    <script>
        // ── State ──────────────────────────────────────────────────────────
        let selectedComplaints = []; // [{name, duration}]
        let selectedExaminations = []; // [{name, value}]
        let selectedInvestigations = []; // [{name, result}]
        let selectedMedicines = []; // [{name, dosage, timing, duration, instruction}]
        let selectedAdvices = []; // [string]
        let selectedDiagnoses = []; // [string]
        let currentTargetTag = '';

        let currentPatient = {
            name: '',
            age: '',
            gender: '',
            phone: ''
        };

        // ── Modal helpers ──────────────────────────────────────────────────
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        // ── Generic badge-grid search ──────────────────────────────────────
        function filterBadgeGrid(gridId, query) {
            const q = query.toLowerCase();
            document.querySelectorAll(`#${gridId} button`).forEach(btn => {
                btn.classList.toggle('hidden', !btn.textContent.toLowerCase().includes(q));
            });
        }

        // ── Medicine catalog search ────────────────────────────────────────
        function filterMedicineCatalog(query) {
            const q = query.toLowerCase();
            document.querySelectorAll('.med-catalog-btn').forEach(btn => {
                btn.classList.toggle('hidden', !btn.dataset.medname.includes(q));
            });
        }

        // ── Patient management ─────────────────────────────────────────────
        function setActivePatient(name, age, gender, phone) {
            currentPatient = {
                name,
                age,
                gender,
                phone: phone || ''
            };
            document.getElementById('current-patient-label').innerText = name;
            document.getElementById('current-patient-meta').innerText = `${age} Years | ${gender}`;
            document.getElementById('canvas-pt-name').innerText = name;
            document.getElementById('canvas-pt-meta').innerText = `${age} Years | ${gender}`;
            closeModal('patient-session-modal');
        }

        function registerQuickPatient() {
            const name = document.getElementById('new-pt-name').value.trim();
            const age = document.getElementById('new-pt-age').value.trim();
            const gender = document.getElementById('new-pt-gender').value;
            const phone = document.getElementById('new-pt-phone').value.trim();
            if (!name || !age) {
                alert('Please enter name and age.');
                return;
            }

            const cardHtml = `
            <div onclick="setActivePatient('${name}','${age}','${gender}','${phone}')"
                 class="patient-ledger-card p-3 border border-slate-100 bg-slate-50/50 hover:bg-indigo-50/20 rounded-xl flex justify-between items-center cursor-pointer hover:border-indigo-400 transition-all">
                <div>
                    <h4 class="text-xs font-bold text-slate-900 name-field">${name}</h4>
                    <p class="text-[10px] text-slate-400 font-medium">Age: ${age} • ${gender}${phone ? ' • '+phone : ''}</p>
                </div>
                <span class="text-[10px] text-slate-400 font-bold">Select</span>
            </div>`;
            document.getElementById('patient-ledger-list').insertAdjacentHTML('afterbegin', cardHtml);
            setActivePatient(name, age, gender, phone);
            document.getElementById('quick-patient-form').reset();
        }

        function filterPatientList(query) {
            const q = query.toLowerCase();
            document.querySelectorAll('.patient-ledger-card').forEach(card => {
                card.classList.toggle('hidden', !card.querySelector('.name-field').innerText.toLowerCase().includes(
                    q));
            });
        }

        // ── Complaints ─────────────────────────────────────────────────────
        function selectComplaintTag(btn, tag) {
            btn.parentNode.querySelectorAll('button').forEach(b => b.classList.remove('bg-indigo-600', 'text-white'));
            btn.classList.add('bg-indigo-600', 'text-white');
            currentTargetTag = tag;
            document.getElementById('active-complaint-label').innerText = tag;
            document.getElementById('complaint-duration-builder').classList.remove('hidden');
        }

        function appendDurationValue(val) {
            document.getElementById('complaint-duration-input').value = val;
        }

        function appendCustomComplaintTag() {
            const v = document.getElementById('custom-complaint-input').value.trim();
            if (!v) return;
            const grid = document.getElementById('complaints-badge-grid');
            grid.insertAdjacentHTML('beforeend',
                `<button type="button" onclick="selectComplaintTag(this,'${v}')" class="badge-btn bg-indigo-50 border border-indigo-200 text-indigo-700 text-xs font-bold px-3.5 py-2.5 rounded-xl transition-all">${v}</button>`
                );
            document.getElementById('custom-complaint-input').value = '';
            selectComplaintTag(grid.lastChild, v);
        }

        function saveComplaintsPipeline() {
            const duration = document.getElementById('complaint-duration-input').value || '3 days';
            if (currentTargetTag) {
                selectedComplaints = selectedComplaints.filter(i => i.name !== currentTargetTag);
                selectedComplaints.push({
                    name: currentTargetTag,
                    duration
                });
                renderComplaintsView();
            }
            document.getElementById('complaint-duration-builder').classList.add('hidden');
            closeModal('complaints-modal');
        }

        function renderComplaintsView() {
            const c = document.getElementById('render-complaints-target');
            const s = document.getElementById('live-section-complaints');
            c.innerHTML = '';
            if (selectedComplaints.length > 0) {
                s.classList.remove('hidden');
                selectedComplaints.forEach(i => {
                    c.innerHTML +=
                        `<div class="font-bold text-slate-900 text-xs py-0.5">• ${i.name} (${i.duration})</div>`;
                });
            } else {
                s.classList.add('hidden');
            }
        }

        // ── Examinations ───────────────────────────────────────────────────
        function selectExaminationTag(btn, tag) {
            btn.parentNode.querySelectorAll('button').forEach(b => b.classList.remove('bg-indigo-600', 'text-white'));
            btn.classList.add('bg-indigo-600', 'text-white');
            currentTargetTag = tag;
            document.getElementById('active-exam-label').innerText = tag;
            document.getElementById('exam-value-input').value = '';
            document.getElementById('exam-value-builder').classList.remove('hidden');
        }

        function appendExamMetric(val) {
            document.getElementById('exam-value-input').value = val;
        }

        function appendCustomExamTag() {
            const v = document.getElementById('custom-exam-name').value.trim();
            if (!v) return;
            const grid = document.getElementById('examination-badge-grid');
            grid.insertAdjacentHTML('beforeend',
                `<button type="button" onclick="selectExaminationTag(this,'${v}')" class="badge-btn bg-blue-50 border border-blue-200 text-blue-700 text-xs font-bold px-3.5 py-2.5 rounded-xl transition-all shadow-sm">${v}</button>`
                );
            document.getElementById('custom-exam-name').value = '';
            selectExaminationTag(grid.lastChild, v);
        }

        function saveExaminationPipeline() {
            const val = document.getElementById('exam-value-input').value || 'Normal';
            if (currentTargetTag) {
                selectedExaminations = selectedExaminations.filter(i => i.name !== currentTargetTag);
                selectedExaminations.push({
                    name: currentTargetTag,
                    value: val
                });
                renderExaminationView();
            }
            document.getElementById('exam-value-builder').classList.add('hidden');
            closeModal('examination-modal');
        }

        function renderExaminationView() {
            const c = document.getElementById('render-examination-target');
            const s = document.getElementById('live-section-examination');
            c.innerHTML = '';
            if (selectedExaminations.length > 0) {
                s.classList.remove('hidden');
                selectedExaminations.forEach(i => {
                    c.innerHTML +=
                        `<div class="text-slate-800 py-0.5 text-xs font-bold">• ${i.name}: <span class="text-indigo-600">${i.value}</span></div>`;
                });
            } else {
                s.classList.add('hidden');
            }
        }

        // ── Diagnoses ──────────────────────────────────────────────────────
        function toggleDiagnosisTag(btn, val) {
            if (btn.classList.contains('bg-indigo-600')) {
                btn.className =
                    'badge-btn bg-slate-50 border border-slate-200/80 text-slate-700 text-xs font-bold px-4 py-3 rounded-xl select-none';
                selectedDiagnoses = selectedDiagnoses.filter(i => i !== val);
            } else {
                btn.className =
                    'badge-btn bg-indigo-600 border border-indigo-600 text-white text-xs font-bold px-4 py-3 rounded-xl select-none';
                selectedDiagnoses.push(val);
            }
        }

        function appendCustomDiagnosisTag() {
            const v = document.getElementById('custom-diagnosis-input').value.trim();
            if (!v) return;
            const grid = document.getElementById('diagnosis-badge-grid');
            grid.insertAdjacentHTML('beforeend',
                `<button type="button" onclick="toggleDiagnosisTag(this,'${v}')" class="badge-btn bg-indigo-600 border border-indigo-600 text-white text-xs font-bold px-4 py-3 rounded-xl">${v}</button>`
                );
            selectedDiagnoses.push(v);
            document.getElementById('custom-diagnosis-input').value = '';
        }

        function saveDiagnosisPipeline() {
            renderDiagnosisView();
            closeModal('diagnosis-modal');
        }

        function renderDiagnosisView() {
            const c = document.getElementById('render-diagnosis-target');
            const s = document.getElementById('live-section-diagnosis');
            c.innerHTML = '';
            if (selectedDiagnoses.length > 0) {
                s.classList.remove('hidden');
                selectedDiagnoses.forEach(d => {
                    c.innerHTML +=
                        `<div class="text-slate-900 py-0.5 text-xs font-extrabold italic">• Provisional Dx: <span class="text-rose-600 font-black">${d}</span></div>`;
                });
            } else {
                s.classList.add('hidden');
            }
        }

        // ── Investigations ─────────────────────────────────────────────────
        function selectInvestigationTag(btn, code) {
            btn.parentNode.querySelectorAll('button').forEach(b => b.classList.remove('bg-purple-600', 'text-white'));
            btn.classList.add('bg-purple-600', 'text-white');
            currentTargetTag = code;
            document.getElementById('active-investigation-label').innerText = code;
            document.getElementById('investigation-result-input').value = '';
            document.getElementById('investigation-result-builder').classList.remove('hidden');
        }

        function appendCustomInvestigationTag() {
            const v = document.getElementById('custom-investigation-input').value.trim();
            if (!v) return;
            const grid = document.getElementById('investigation-badge-grid');
            grid.insertAdjacentHTML('beforeend',
                `<button type="button" onclick="selectInvestigationTag(this,'${v}')" class="badge-btn bg-purple-50 border border-purple-200 text-purple-700 text-xs font-bold px-3.5 py-2.5 rounded-xl">${v}</button>`
                );
            document.getElementById('custom-investigation-input').value = '';
            selectInvestigationTag(grid.lastChild, v);
        }

        function saveInvestigationPipeline() {
            const result = document.getElementById('investigation-result-input').value || 'Normal';
            if (currentTargetTag) {
                selectedInvestigations = selectedInvestigations.filter(i => i.name !== currentTargetTag);
                selectedInvestigations.push({
                    name: currentTargetTag,
                    result
                });
                renderInvestigationsView();
            }
            document.getElementById('investigation-result-builder').classList.add('hidden');
            closeModal('investigation-modal');
        }

        function renderInvestigationsView() {
            const c = document.getElementById('render-investigation-target');
            const s = document.getElementById('live-section-investigation');
            c.innerHTML = '';
            if (selectedInvestigations.length > 0) {
                s.classList.remove('hidden');
                selectedInvestigations.forEach(i => {
                    c.innerHTML +=
                        `<div class="text-slate-900 py-0.5 text-xs font-bold">• ${i.name} <span class="text-purple-600 font-medium ml-1">[${i.result}]</span></div>`;
                });
            } else {
                s.classList.add('hidden');
            }
        }

        // ── Medicines ──────────────────────────────────────────────────────
        function stageMedicineItem(btn, drugName) {
            btn.parentNode.querySelectorAll('button').forEach(b => b.classList.remove('bg-indigo-50', 'border-indigo-300'));
            btn.classList.add('bg-indigo-50', 'border-indigo-300');
            currentTargetTag = drugName;
            document.getElementById('med-placeholder-notice').classList.add('hidden');
            document.getElementById('med-scheduler-panel').classList.remove('hidden');
            document.getElementById('scheduled-med-title').innerText = drugName;
        }

        function appendCustomMedicineCatalog() {
            const v = document.getElementById('custom-medicine-name').value.trim();
            if (!v) return;
            const catalog = document.getElementById('medicine-catalog-list');
            catalog.insertAdjacentHTML('afterbegin',
                `<button type="button" onclick="stageMedicineItem(this,'${v}')" data-medname="${v.toLowerCase()}"
             class="med-catalog-btn text-left text-xs text-indigo-600 font-semibold py-2.5 px-3 bg-indigo-50/30 border border-indigo-200 rounded-xl w-full flex items-center space-x-2"><span>✨</span><span>${v}</span></button>`
                );
            document.getElementById('custom-medicine-name').value = '';
            stageMedicineItem(catalog.firstChild, v);
        }

        function commitMedicineToStack() {
            const m = document.getElementById('check-morn').checked ? document.getElementById('dose-qty-1').value : '0';
            const d = document.getElementById('check-noon').checked ? document.getElementById('dose-qty-2').value : '0';
            const n = document.getElementById('check-night').checked ? document.getElementById('dose-qty-3').value : '0';
            const e = document.getElementById('check-eve').checked ? document.getElementById('dose-qty-4').value : '0';

            selectedMedicines.push({
                name: currentTargetTag,
                dosage: `${m} + ${d} + ${n} + ${e}`,
                timing: document.getElementById('med-timing-select').value,
                duration: document.getElementById('med-duration-input').value,
                instruction: document.getElementById('med-instruction-input').value,
            });
            renderMedicinesView();
            document.getElementById('med-scheduler-panel').classList.add('hidden');
            document.getElementById('med-placeholder-notice').classList.remove('hidden');
            closeModal('medicine-modal');
        }

        function renderMedicinesView() {
            const c = document.getElementById('render-medication-target');
            const s = document.getElementById('live-section-medication');
            const notice = document.getElementById('med-blank-canvas-notice');
            c.innerHTML = '';
            if (selectedMedicines.length > 0) {
                s.classList.remove('hidden');
                notice.classList.add('hidden');
                selectedMedicines.forEach(item => {
                    c.innerHTML += `
                    <li class="mb-1 pl-1 text-slate-900 font-bold">
                        <div class="text-sm font-extrabold">${item.name}</div>
                        <div class="text-xs text-slate-500 font-medium mt-0.5">
                            💥 <span class="text-slate-800 font-bold">${item.dosage}</span>
                            — <span class="text-slate-600 bg-slate-100 px-1.5 py-0.5 rounded">${item.timing}</span>
                            — <span class="text-indigo-600 font-extrabold">${item.duration}</span>
                            ${item.instruction ? `<br><span class="text-amber-700 text-[11px] font-bold bg-amber-50 px-2 py-0.5 rounded-lg mt-1 inline-block">Instruction: ${item.instruction}</span>` : ''}
                        </div>
                    </li>`;
                });
            } else {
                s.classList.add('hidden');
                notice.classList.remove('hidden');
            }
        }

        // ── Advices ────────────────────────────────────────────────────────
        function toggleAdviceTag(btn, val) {
            if (btn.classList.contains('bg-indigo-600')) {
                btn.className =
                    'badge-btn bg-slate-50 border border-slate-200/80 text-slate-700 text-xs font-bold px-4 py-3 rounded-xl select-none';
                selectedAdvices = selectedAdvices.filter(i => i !== val);
            } else {
                btn.className =
                    'badge-btn bg-indigo-600 border border-indigo-600 text-white text-xs font-bold px-4 py-3 rounded-xl shadow-sm select-none';
                selectedAdvices.push(val);
            }
        }

        function appendCustomAdviceTag() {
            const v = document.getElementById('custom-advice-input').value.trim();
            if (!v) return;
            const grid = document.getElementById('advices-badge-grid');
            grid.insertAdjacentHTML('beforeend',
                `<button type="button" onclick="toggleAdviceTag(this,'${v}')" class="badge-btn bg-indigo-600 border border-indigo-600 text-white text-xs font-bold px-4 py-3 rounded-xl">${v}</button>`
                );
            selectedAdvices.push(v);
            document.getElementById('custom-advice-input').value = '';
        }

        function saveAdvicePipeline() {
            const c = document.getElementById('render-advice-target');
            const s = document.getElementById('live-section-advice');
            c.innerHTML = '';
            if (selectedAdvices.length > 0) {
                s.classList.remove('hidden');
                selectedAdvices.forEach(a => {
                    c.innerHTML += `<li class="text-xs font-bold text-slate-800 py-0.5">${a}</li>`;
                });
            } else {
                s.classList.add('hidden');
            }
            closeModal('advice-modal');
        }

        // ── Treatment Templates ────────────────────────────────────────────
        const treatmentTemplates = {
            fever_pack: {
                title: 'HN-01: Standard Fever & Flu',
                complaints: [{
                    name: 'Fever',
                    duration: '3 days'
                }, {
                    name: 'Cough',
                    duration: '7 days'
                }],
                examination: [{
                    name: 'Pulse',
                    value: '92 bpm'
                }, {
                    name: 'Blood Pressure',
                    value: '120/70'
                }],
                investigations: [{
                    name: 'Serum Uric Acid',
                    result: 'High'
                }],
                diagnoses: ['Gout'],
                medicines: [{
                        name: 'Tab. Febus 80 mg',
                        dosage: '0 + 0 + 1 + 0',
                        timing: 'খাবারের পরে',
                        duration: 'চলবে',
                        instruction: ''
                    },
                    {
                        name: 'Tab. Kochin 0.6',
                        dosage: '1 + 1 + 1 + 0',
                        timing: 'খাবারের পরে',
                        duration: '৫ দিন',
                        instruction: ''
                    },
                    {
                        name: 'Tab. Naprosyn Plus',
                        dosage: '1 + 0 + 1 + 0',
                        timing: 'খাবারের পরে',
                        duration: '১ সপ্তাহ',
                        instruction: 'জ্বর থাকলে'
                    },
                ],
                advices: ['Drink plenty of fluids', 'Take rest'],
            }
        };

        function filterTreatmentTemplatesList(q) {
            document.querySelectorAll('#ui-templates-container .template-wrapper-item').forEach(item => {
                item.classList.toggle('hidden', !item.dataset.title.includes(q.toLowerCase()));
            });
        }

        function loadTreatmentTemplate(key) {
            const pack = treatmentTemplates[key];
            if (!pack) return;
            selectedComplaints = [...pack.complaints];
            selectedExaminations = [...pack.examination];
            selectedInvestigations = pack.investigations ? [...pack.investigations] : [];
            selectedDiagnoses = pack.diagnoses ? [...pack.diagnoses] : [];
            selectedMedicines = [...pack.medicines];
            selectedAdvices = [...pack.advices];
            renderComplaintsView();
            renderExaminationView();
            renderInvestigationsView();
            renderDiagnosisView();
            renderMedicinesView();
            saveAdvicePipeline();
        }

        function createNewTreatmentTemplateFromUI() {
            const titleInput = document.getElementById('custom-template-title-input');
            const title = titleInput.value.trim();
            if (!title) {
                alert('Specify template name.');
                return;
            }
            const key = 'custom_' + Date.now();
            treatmentTemplates[key] = {
                title,
                complaints: [...selectedComplaints],
                examination: [...selectedExaminations],
                investigations: [...selectedInvestigations],
                diagnoses: [...selectedDiagnoses],
                medicines: [...selectedMedicines],
                advices: [...selectedAdvices]
            };
            const searchMeta = title.toLowerCase().replace(/[^a-z0-9 ]/g, '');
            document.getElementById('ui-templates-container').insertAdjacentHTML('beforeend',
                `<div class="template-wrapper-item" data-title="${searchMeta}">
                <button type="button" onclick="loadTreatmentTemplate('${key}')"
                        class="w-full text-left text-xs font-bold px-4 py-3 bg-emerald-50/60 hover:bg-indigo-600 text-emerald-950 hover:text-white border border-emerald-100 rounded-xl flex items-center justify-between group shadow-sm active:scale-95">
                    <span>📋 ${title}</span>
                    <span class="text-[10px] bg-white text-emerald-700 tracking-wide uppercase px-1.5 py-0.5 rounded">Load</span>
                </button>
             </div>`);
            titleInput.value = '';
        }

        // ── Print View ─────────────────────────────────────────────────────
        function hydratePrintTargetView(targetId, dataArray, templateFn, blockId) {
            const c = document.getElementById(targetId);
            const b = document.getElementById(blockId);
            c.innerHTML = '';
            if (dataArray.length > 0) {
                if (b) b.classList.remove('hidden');
                dataArray.forEach(item => {
                    c.innerHTML += templateFn(item);
                });
            } else {
                if (b) b.classList.add('hidden');
            }
        }

        function routeToPrintPrescriptionPage() {
            if (!currentPatient.name) {
                alert('Please select a patient before printing.');
                return;
            }
            document.getElementById('workspace-main-panel').classList.add('hidden');
            document.querySelector('aside').classList.add('hidden');

            document.getElementById('print-target-name').innerText = currentPatient.name;
            document.getElementById('print-target-age').innerText = currentPatient.age + ' yrs';
            document.getElementById('print-target-gender').innerText = currentPatient.gender;

            hydratePrintTargetView('print-target-complaints', selectedComplaints,
                i => `<div>• ${i.name} (${i.duration})</div>`, 'print-block-complaints');
            hydratePrintTargetView('print-target-diagnosis', selectedDiagnoses,
                i => `<div>• Provisional Dx: ${i}</div>`, 'print-block-diagnosis');
            hydratePrintTargetView('print-target-examination', selectedExaminations,
                i => `<div>• ${i.name}: ${i.value}</div>`, 'print-block-examination');
            hydratePrintTargetView('print-target-investigation', selectedInvestigations,
                i => `<div>• ${i.name} [${i.result}]</div>`, 'print-block-investigation');
            hydratePrintTargetView('print-target-advice', selectedAdvices,
                i => `<li>${i}</li>`, 'print-block-advice');

            const medContainer = document.getElementById('print-target-medication');
            medContainer.innerHTML = '';
            if (selectedMedicines.length > 0) {
                selectedMedicines.forEach(item => {
                    medContainer.innerHTML += `
                    <li class="pl-2 mb-2">
                        <div class="text-sm font-black text-black">${item.name}</div>
                        <div class="text-xs text-slate-800 font-semibold mt-0.5">
                            &nbsp;&nbsp;&nbsp;&nbsp;${item.dosage}
                            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;— ${item.timing} — ${item.duration}
                            ${item.instruction ? `<br>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-xs font-bold italic text-slate-700">${item.instruction}</span>` : ''}
                        </div>
                    </li>`;
                });
            }

            document.getElementById('print-prescription-view').classList.remove('hidden');
        }

        function exitPrintPrescriptionView() {
            document.getElementById('print-prescription-view').classList.add('hidden');
            document.getElementById('workspace-main-panel').classList.remove('hidden');
            document.querySelector('aside').className =
                'w-64 bg-slate-900 text-slate-200 flex flex-col fixed inset-y-0 left-0 z-40 shadow-xl no-print';
        }

        // ── Save to DB ─────────────────────────────────────────────────────
        // FIX: accept btn element directly (onclick passes `this`) — no longer relies on event.currentTarget
        function commitPrescriptionToDatabase(btn) {
            if (!currentPatient.name) {
                alert('Please select a patient first.');
                return;
            }
            if (selectedMedicines.length === 0 && selectedComplaints.length === 0) {
                alert('Add at least one complaint or medicine before saving.');
                return;
            }

            const payload = {
                patient: currentPatient,
                complaints: selectedComplaints,
                examinations: selectedExaminations,
                diagnoses: selectedDiagnoses,
                investigations: selectedInvestigations,
                advices: selectedAdvices,
                medicines: selectedMedicines,
            };

            // Disable button so it can't be double-clicked
            if (btn) {
                btn.disabled = true;
                btn.innerText = 'Saving…';
            }

            fetch("{{ route('prescriptions.store') }}", {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                    },
                    body: JSON.stringify(payload),
                })
                .then(res => {
                    // FIX: parse JSON first so we can show the real server error message
                    return res.json().then(data => ({
                        ok: res.ok,
                        status: res.status,
                        data
                    }));
                })
                .then(({
                    ok,
                    status,
                    data
                }) => {
                    if (ok && data.success) {
                        alert('✅ Prescription #' + data.id + ' saved successfully!');
                    } else {
                        // Show the actual error from the server (visible in the alert now)
                        const msg = data.message || ('Server returned HTTP ' + status);
                        alert('❌ Save failed:\n\n' + msg);
                        console.error('Server error detail:', data);
                    }
                })
                .catch(err => {
                    alert('❌ Network/JS error:\n\n' + err.message);
                    console.error(err);
                })
                .finally(() => {
                    if (btn) {
                        btn.disabled = false;
                        btn.innerText = 'Save Record 💾';
                    }
                });
        }

        // "Print + Finalize" saves first, then opens print if save succeeds
        function routeToPrintPrescriptionPage() {
            if (!currentPatient.name) {
                alert('Please select a patient first.');
                return;
            }
            // Build print view directly (save is separate button)
            document.getElementById('workspace-main-panel').classList.add('hidden');
            document.querySelector('aside').classList.add('hidden');

            document.getElementById('print-target-name').innerText = currentPatient.name;
            document.getElementById('print-target-age').innerText = currentPatient.age + ' yrs';
            document.getElementById('print-target-gender').innerText = currentPatient.gender;

            hydratePrintTargetView('print-target-complaints', selectedComplaints,
                i => `<div>• ${i.name} (${i.duration})</div>`, 'print-block-complaints');
            hydratePrintTargetView('print-target-diagnosis', selectedDiagnoses,
                i => `<div>• Provisional Dx: ${i}</div>`, 'print-block-diagnosis');
            hydratePrintTargetView('print-target-examination', selectedExaminations,
                i => `<div>• ${i.name}: ${i.value}</div>`, 'print-block-examination');
            hydratePrintTargetView('print-target-investigation', selectedInvestigations,
                i => `<div>• ${i.name} [${i.result}]</div>`, 'print-block-investigation');
            hydratePrintTargetView('print-target-advice', selectedAdvices,
                i => `<li>${i}</li>`, 'print-block-advice');

            const medContainer = document.getElementById('print-target-medication');
            medContainer.innerHTML = '';
            selectedMedicines.forEach(item => {
                medContainer.innerHTML += `
                <li class="pl-2 mb-2">
                    <div class="text-sm font-black text-black">${item.name}</div>
                    <div class="text-xs text-slate-800 font-semibold mt-0.5">
                        &nbsp;&nbsp;&nbsp;&nbsp;${item.dosage}
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;— ${item.timing} — ${item.duration}
                        ${item.instruction ? `<br>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-xs font-bold italic text-slate-700">${item.instruction}</span>` : ''}
                    </div>
                </li>`;
            });

            document.getElementById('print-prescription-view').classList.remove('hidden');
        }
    </script>
</body>

</html>
